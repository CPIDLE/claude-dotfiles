# === Google Workspace Integration (optional) ===
# See docs/google-workspace-setup.md for setup instructions
CHAT_WEBHOOK_URL=<YOUR_CHAT_WEBHOOK_URL>
DASHBOARD_SHEET_ID=<YOUR_DASHBOARD_SHEET_ID>
APPS_SCRIPT_WEB_APP_ID=<YOUR_APPS_SCRIPT_WEB_APP_ID>

