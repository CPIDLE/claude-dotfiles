{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import json,time,pathlib,sys; f=pathlib.Path.home()/'.claude'/'usage-cache.json'; c=json.loads(f.read_text()) if f.exists() else {}; ts=c.get('ts',0); stale=time.time()-ts/1000>600; s=c.get('session',{}).get('utilization',0); w=c.get('week',{}).get('utilization',0); red=not stale and (s>=80 or w>=80); print(f'⚠️ QUOTA RED (5h={s}% 7d={w}%) — 適合委派的任務必須用 /do（easy 或 deep）。不符合委派條件的才自己處理。') if red else sys.exit(0)\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[console]::beep(1000,500)\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/pm-update.sh reset"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[console]::beep(800,500); Start-Sleep -Milliseconds 300; [console]::beep(800,500); Start-Sleep -Milliseconds 300; [console]::beep(800,500)\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
