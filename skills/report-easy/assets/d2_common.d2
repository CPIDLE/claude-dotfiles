# Shared style classes — import via:  ...@d2_common.d2
classes: {
  trigger: {
    style: {
      fill: "#e0f2fe"
      stroke: "#0284c7"
      stroke-width: 2
      font-color: "#0c4a6e"
      border-radius: 10
      shadow: true
    }
  }
  reasoning: {
    style: {
      fill: "#fef3c7"
      stroke: "#d97706"
      stroke-width: 3
      font-color: "#7c2d12"
      border-radius: 12
      shadow: true
      bold: true
    }
  }
  logic: {
    style: {
      fill: "#eef2ff"
      stroke: "#6366f1"
      stroke-width: 2
      font-color: "#1e1b4b"
      border-radius: 10
      shadow: true
    }
  }
  db: {
    shape: cylinder
    style: {
      fill: "#dbeafe"
      stroke: "#2563eb"
      stroke-width: 2
      font-color: "#0c2d6b"
      shadow: true
    }
  }
  human: {
    style: {
      fill: "#ffedd5"
      stroke: "#ea580c"
      stroke-width: 2
      font-color: "#7c2d12"
      border-radius: 10
      shadow: true
    }
  }
  legacy: {
    style: {
      fill: "#f1f5f9"
      stroke: "#64748b"
      stroke-width: 2
      font-color: "#334155"
      stroke-dash: 4
      border-radius: 10
    }
  }
  zone: {
    style: {
      fill: "#fafaf9"
      stroke: "#475569"
      stroke-width: 2
      font-color: "#0f172a"
      border-radius: 14
      bold: true
    }
  }
  invisible: {
    style: {
      fill: transparent
      stroke-width: 0
    }
  }
  step: {
    style: {
      fill: "#f0fdf4"
      stroke: "#16a34a"
      stroke-width: 2
      font-color: "#14532d"
      border-radius: 10
      shadow: true
    }
  }
}
